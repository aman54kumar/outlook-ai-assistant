# Copy to .env to pre-configure providers on the server.
# You can also set everything from the task pane settings drawer —
# values entered there take precedence over this file.

# ── Local (Ollama) ────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ── Cloud provider ────────────────────────────────────────────────────────────
# Set CLOUD_PROVIDER to one of: openai | anthropic | google | custom
# CLOUD_PROVIDER=openai
# CLOUD_MODEL=gpt-4o-mini

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (uses the OpenAI-compatible endpoint automatically)
# OPENAI_API_KEY=<your Gemini API key from aistudio.google.com>
# CLOUD_PROVIDER=google
# CLOUD_MODEL=gemini-2.0-flash

# Any OpenAI-compatible endpoint (Groq, Together.ai, Mistral, Ollama, etc.)
# CLOUD_PROVIDER=custom
# CLOUD_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=<provider key>
# CLOUD_MODEL=llama-3.1-70b-versatile
